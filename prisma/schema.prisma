generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Seller {
  id                 String             @id @default(cuid())
  clerkUserId        String?
  email              String
  passwordHash       String?
  businessName       String
  businessAddress    String?
  phone              String?
  logo               String?
  taxId              String?
  bankDetails        Json?
  invoiceDefaults    Json?
  integrations       Json?
  magicLinkToken     String?            @unique
  magicLinkExpiry    DateTime?
  emailVerified      Boolean            @default(false)
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  state              String?
  logoData           Bytes?
  cancelledAt        DateTime?
  customerId         String?
  invoicesCount      Int                @default(0)
  lastResetDate      DateTime           @default(now())
  ocrUsage           Int                @default(0)
  pdfApiUsage        Int                @default(0)
  plan               PlanTier           @default(FREE)
  subscriptionEndsAt DateTime?
  subscriptionId     String?
  apiKeys            ApiKey[]
  buyers             Buyer[]
  invoices           Invoice[]
  paymentMethods     PaymentMethod[]
  paymentReminders   PaymentReminder[]
  members            TeamMember[]
  uploadedDocuments  UploadedDocument[]
  inventoryItems     InventoryItem[]
  referredByCode     String? // Track referrers who referred this seller

  @@index([clerkUserId])
  @@index([email])
}

model PaymentMethod {
  id        String            @id @default(cuid())
  sellerId  String
  type      PaymentMethodType
  details   Json
  isEnabled Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  seller    Seller            @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
}

model Buyer {
  id        String    @id @default(cuid())
  sellerId  String
  name      String
  email     String?
  phone     String?
  address   String?
  taxId     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  state     String?
  seller    Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  invoices  Invoice[]

  @@unique([sellerId, email])
  @@index([sellerId])
  @@index([name])
}

model Invoice {
  id               String                @id @default(cuid())
  invoiceNumber    String
  sellerId         String
  buyerId          String?
  issueDate        DateTime              @default(now())
  dueDate          DateTime?
  status           InvoiceStatus         @default(DRAFT)
  paymentStatus    PaymentStatus         @default(DRAFT)
  deliveryStatus   InvoiceDeliveryStatus @default(DRAFT)
  subtotal         Decimal               @db.Decimal(12, 2)
  taxAmount        Decimal               @default(0) @db.Decimal(12, 2)
  discountAmount   Decimal               @default(0) @db.Decimal(12, 2)
  totalAmount      Decimal               @db.Decimal(12, 2)
  currency         String                @default("INR")
  notes            String?
  terms            String?
  verificationHash String                @unique
  signature        String
  pdfUrl           String?
  sourceType       SourceType            @default(MANUAL)
  sourceDocumentId String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  cgstAmount       Decimal               @default(0) @db.Decimal(12, 2)
  igstAmount       Decimal               @default(0) @db.Decimal(12, 2)
  pdfData          Bytes?
  sgstAmount       Decimal               @default(0) @db.Decimal(12, 2)
  deliveryLogs     DeliveryLog[]
  buyer            Buyer?                @relation(fields: [buyerId], references: [id])
  seller           Seller                @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  sourceDocument   UploadedDocument?     @relation(fields: [sourceDocumentId], references: [id])
  activities       InvoiceActivity[]
  items            InvoiceItem[]
  paymentReminders PaymentReminder[]

  @@unique([sellerId, invoiceNumber])
  @@index([sellerId])
  @@index([buyerId])
  @@index([verificationHash])
  @@index([issueDate])
  @@index([status])
  @@index([paymentStatus])
  @@index([deliveryStatus])
}

model InvoiceActivity {
  id          String       @id @default(cuid())
  invoiceId   String
  type        ActivityType
  title       String
  description String?
  actorType   ActorType    @default(SYSTEM)
  actorId     String?
  actorName   String?
  metadata    Json?
  createdAt   DateTime     @default(now())
  invoice     Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([type])
  @@index([createdAt])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Decimal  @db.Decimal(10, 3)
  unit        String   @default("pcs")
  unitPrice   Decimal  @db.Decimal(12, 2)
  taxRate     Decimal  @default(0) @db.Decimal(5, 2)
  discount    Decimal  @default(0) @db.Decimal(12, 2)
  amount      Decimal  @db.Decimal(12, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cgstAmount  Decimal  @default(0) @db.Decimal(12, 2)
  cgstRate    Decimal  @default(0) @db.Decimal(5, 2)
  igstAmount  Decimal  @default(0) @db.Decimal(12, 2)
  igstRate    Decimal  @default(0) @db.Decimal(5, 2)
  sgstAmount  Decimal  @default(0) @db.Decimal(12, 2)
  sgstRate    Decimal  @default(0) @db.Decimal(5, 2)
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model UploadedDocument {
  id               String           @id @default(cuid())
  sellerId         String
  originalName     String
  storagePath      String?
  mimeType         String
  fileSize         Int
  pageCount        Int              @default(1)
  processingStatus ProcessingStatus @default(PENDING)
  ocrResult        Json?
  extractedData    Json?
  confidence       Decimal?         @db.Decimal(5, 2)
  errorMessage     String?
  createdAt        DateTime         @default(now())
  processedAt      DateTime?
  fileData         Bytes?
  invoices         Invoice[]
  seller           Seller           @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([processingStatus])
}

model DeliveryLog {
  id           String         @id @default(cuid())
  invoiceId    String
  method       DeliveryMethod
  recipient    String
  status       DeliveryStatus @default(PENDING)
  messageId    String?
  errorMessage String?
  createdAt    DateTime       @default(now())
  sentAt       DateTime?
  deliveredAt  DateTime?
  invoice      Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([status])
}

model PaymentReminder {
  id           String         @id @default(cuid())
  invoiceId    String
  sellerId     String
  type         ReminderType   @default(BEFORE_DUE)
  daysOffset   Int            @default(0)
  channel      DeliveryMethod @default(EMAIL)
  scheduledFor DateTime
  status       ReminderStatus @default(PENDING)
  sentAt       DateTime?
  errorMessage String?
  messageId    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  invoice      Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  seller       Seller         @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([sellerId])
  @@index([scheduledFor])
  @@index([status])
}

model VerificationLog {
  id        String   @id @default(cuid())
  hash      String
  ipAddress String?
  userAgent String?
  result    Boolean
  createdAt DateTime @default(now())

  @@index([hash])
  @@index([createdAt])
}

model InventoryItem {
  id          String   @id @default(cuid())
  sellerId    String
  description String
  note        String?
  sku         String?
  hsnCode     String?
  quantity    Int      @default(0)
  unit        String   @default("pcs")
  price       Decimal  @db.Decimal(12, 2)
  taxRate     Decimal  @default(0) @db.Decimal(5, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  barcode     String?
  seller      Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([barcode])
  @@map("inventory_management")
}

model TeamMember {
  id        String       @id @default(cuid())
  sellerId  String
  email     String
  role      MemberRole   @default(VIEWER)
  status    MemberStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  seller    Seller       @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([sellerId, email])
  @@index([sellerId])
  @@index([email])
}

model ApiKey {
  id         String    @id @default(cuid())
  sellerId   String
  name       String
  key        String    @unique
  templateId String    @default("classic")
  usage      Int       @default(0)
  limit      Int       @default(100000)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  seller     Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([key])
}

model SiteConfig {
  id             String    @id @default(cuid())
  offerEnabled   Boolean   @default(false)
  offerText      String?
  offerHref      String?
  offerBadge     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  themeColors    String?
  themeEmojis    String?
  themeEnabled   Boolean   @default(false)
  themeEndDate   DateTime?
  themeIntensity String    @default("medium")
  themeGreeting  String?
  themeName      String?
  themeStartDate DateTime?
  fromEmail      String?
  smtpHost       String?
  smtpPass       String?
  smtpPort       String?   @default("587")
  smtpUser       String?
  offerBgColor   String?
  offerBorder    Boolean   @default(true)
  offerStyle     String?   @default("modern")
  offerAnimation String?   @default("slide")
}

model Referral {
  id              String                  @id @default(cuid())
  code            String                  @unique
  referrerName    String
  referrerEmail   String
  description     String?
  rewardType      String                  @default("discount")   // discount | credit | commission
  rewardValue     String?                                         // e.g. "10%" or "₹500"
  isActive        Boolean                 @default(true)
  clicks          Int                     @default(0)
  signups         Int                     @default(0)
  conversions     Int                     @default(0)
  maxUses         Int?                                             // null = unlimited
  expiresAt       DateTime?
  accessToken     String?                 @unique                 // for referrer portal login
  totalEarned     Decimal                 @default(0) @db.Decimal(12, 2)
  totalPaid       Decimal                 @default(0) @db.Decimal(12, 2)
  payoutDay       Int                     @default(15)            // day of month for payout
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  paymentMethods  ReferralPaymentMethod[]
  payouts         ReferralPayout[]

  @@index([code])
  @@index([referrerEmail])
  @@index([isActive])
  @@index([accessToken])
}

model ReferralApplication {
  id              String   @id @default(cuid())
  userId          String                           // Clerk user ID
  userName        String
  userEmail       String
  reason          String?                          // why they want to be a referrer
  preferredReward String   @default("commission")  // discount | credit | commission
  socialLinks     String?                          // optional social/website links
  status          String   @default("pending")     // pending | approved | rejected
  adminNote       String?                          // admin response note
  referralId      String?                          // linked Referral once approved
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId])
  @@index([status])
  @@index([userEmail])
}

model ReferralPaymentMethod {
  id          String   @id @default(cuid())
  referralId  String
  type        String                        // "upi" or "paypal"
  label       String?                       // e.g. "My UPI" or "My PayPal"
  upiId       String?                       // UPI VPA
  paypalEmail String?                       // PayPal email
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  referral    Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)

  @@index([referralId])
}

model ReferralPayout {
  id          String   @id @default(cuid())
  referralId  String
  amount      Decimal  @db.Decimal(12, 2)
  status      String   @default("pending")  // pending | processing | completed | failed
  method      String?                        // upi | paypal
  reference   String?                        // transaction reference
  note        String?
  receiptUrl  String?                        // payment confirmation image
  scheduledAt DateTime
  paidAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  referral    Referral @relation(fields: [referralId], references: [id], onDelete: Cascade)

  @@index([referralId])
  @@index([status])
  @@index([scheduledAt])
}

enum PlanTier {
  FREE
  BASIC
  PRO
  PREMIUM
  LIFETIME
}

enum PaymentMethodType {
  BANK_TRANSFER
  UPI
  PAYPAL
  QR_CODE
}

enum ActivityType {
  CREATED
  UPDATED
  STATUS_CHANGED
  SENT
  VIEWED
  VERIFIED
  DOWNLOADED
  REMINDER_SENT
  REMINDER_CREATED
  PAYMENT_RECORDED
  DELETED
}

enum ActorType {
  SELLER
  BUYER
  SYSTEM
  ANONYMOUS
}

enum InvoiceStatus {
  DRAFT
  PENDING
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum InvoiceDeliveryStatus {
  DRAFT
  SENT
  VIEWED
  DOWNLOADED
}

enum SourceType {
  MANUAL
  OCR
  IMPORTED
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REVIEW_NEEDED
}

enum DeliveryMethod {
  EMAIL
  WHATSAPP
  SMS
}

enum DeliveryStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  BOUNCED
}

enum ReminderType {
  BEFORE_DUE
  ON_DUE
  AFTER_DUE
  CUSTOM
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
  SKIPPED
}

enum MemberRole {
  ADMIN
  VIEWER
}

enum MemberStatus {
  PENDING
  ACCEPTED
}
